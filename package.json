{
  "name": "telegram-ssh-bot",
  "version": "2.3.0",
  "description": "A Telegram bot for secure SSH server management and remote command execution",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "author": "farhanzzg",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/farhanzzg/telegram-ssh.git"
  },
  "bugs": {
    "url": "https://github.com/farhanzzg/telegram-ssh/issues"
  },
  "homepage": "https://github.com/farhanzzg/telegram-ssh#readme",
  "bin": {
    "telegram-ssh-bot": "./dist/index.js"
  },
  "files": [
    "dist/**/*",
    "scripts/**/*",
    "deploy/.env.example",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "telegram",
    "telegram-bot",
    "ssh",
    "ssh-client",
    "bot",
    "remote",
    "server-management",
    "server-administration",
    "devops",
    "remote-access",
    "command-execution",
    "terminal"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run build",
    "postinstall": "node scripts/postinstall.js",
    "build:binary": "npm run build && pkg .",
    "build:binary:linux": "npm run build && pkg . --targets node18-linux-x64",
    "build:binary:macos": "npm run build && pkg . --targets node18-macos-x64",
    "build:binary:windows": "npm run build && pkg . --targets node18-win-x64"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "node_modules/ssh2/**/*",
      "node_modules/node-telegram-bot-api/**/*"
    ],
    "targets": [
      "node18-linux-x64",
      "node18-macos-x64",
      "node18-win-x64"
    ],
    "outputPath": "build"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "joi": "^17.11.0",
    "node-telegram-bot-api": "^0.61.0",
    "prompts": "^2.4.2",
    "ssh2": "^1.14.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/node-telegram-bot-api": "^0.61.0",
    "@types/prompts": "^2.4.9",
    "@types/ssh2": "^1.15.0",
    "@yao-pkg/pkg": "^5.11.0",
    "nodemon": "^3.0.1",
    "tsx": "^4.6.0",
    "typescript": "^5.3.0"
  }
}
